{
  "name": "lotto-purchase-action",
  "type": "module",
  "version": "1.1.0",
  "main": "dist/index.js",
  "author": "kkd927 <kkd927@gmail.com>",
  "license": "MIT",
  "packageManager": "npm@11.8.0",
  "scripts": {
    "build": "rm -rf dist/**/**.js && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "fix": "eslint src --fix && prettier --write \"src/**/*.{ts,tsx,js}\"",
    "lint": "tsc --noEmit && eslint src && prettier --check \"src/**/*.{ts,tsx,js}\"",
    "ci": "npm run lint && npm run build"
  },
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/github": "^8.0.1",
    "axios": "^1.16.0",
    "dayjs": "^1.11.8",
    "playwright": "1.55.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.1",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@rollup/plugin-typescript": "^11.1.1",
    "@types/node": "^20.19.33",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9.39.2",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.8.8",
    "rollup": "^3.30.0",
    "tslib": "^2.8.1",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "js-yaml": "^4.1.1"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "none",
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "bracketSameLine": false,
    "proseWrap": "never"
  }
}
